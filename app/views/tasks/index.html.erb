<div class="max-w-7xl mx-auto" dir="ltr">
  <div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-black text-gray-900">My Tasks</h1>
    <%= link_to "Add New Task +", new_task_path, class: "bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:shadow-lg hover:bg-blue-700 transition" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @tasks.each do |task| %>
      <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
        <div class="flex justify-between items-start mb-4">
          <span class="text-xs font-bold uppercase tracking-wider <%= case task.status 
            when 'Done' then 'text-green-500'
            when 'In Progress' then 'text-blue-500'
            else 'text-yellow-500'
          end %>">
            ● <%= task.status %>
          </span>
        </div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 truncate"><%= task.title %></h2>
        <p class="text-gray-500 text-sm line-clamp-2 mb-6"><%= task.description %></p>
        
        <div class="flex justify-between items-center">
          <%= link_to "View Details", task, class: "text-blue-600 font-semibold text-sm hover:underline" %>
          <span class="text-gray-300 text-xs italic">Owner: Me</span>
        </div>
      </div>
    <% end %>
  </div>
</div>