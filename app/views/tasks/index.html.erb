<div class="w-full max-w-3xl mx-auto mt-10 p-6 bg-white shadow-lg rounded-lg">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">My Tasks</h1>
    <%= link_to "New Task", new_task_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition" %>
  </div>

  <div id="tasks" class="divide-y divide-gray-200">
    <% @tasks.each do |task| %>
      <div class="py-4 flex justify-between items-center">
        <div class="flex flex-col">
          <h3 class="text-lg font-semibold text-gray-700"><%= task.title %></h3>
          <div class="flex items-center gap-2 mt-1">
            <p class="text-sm text-gray-500"><%= task.description %></p>
            <span class="<%= case task.status 
              when 'Pending' then 'bg-yellow-100 text-yellow-800'
              when 'Done' then 'bg-green-100 text-green-800'
              else 'bg-blue-100 text-blue-800'
            end %> px-2 py-0.5 rounded-full text-xs font-bold">
              <%= task.status || "Pending" %>
            </span>
          </div>
        </div>
        <div class="flex gap-2">
          <%= link_to "Show", task, class: "text-blue-500 hover:underline text-sm" %>
          <%= link_to "Edit", edit_task_path(task), class: "text-gray-500 hover:underline text-sm" %>
        </div>
      </div>
    <% end %>
  </div>
</div>