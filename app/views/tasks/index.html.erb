<div class="max-w-7xl mx-auto px-4 py-8">
  
  <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
    <div>
      <h1 class="text-4xl font-black text-gray-900">My Tasks</h1>
      <p class="text-gray-500 mt-1 font-medium">Manage your daily activities and deadlines</p>
    </div>
    
    <div class="flex items-center gap-3">
      <%= link_to new_task_path, class: "bg-blue-600 text-white px-8 py-3 rounded-2xl font-bold shadow-lg shadow-blue-500/30 hover:bg-blue-700 transition" do %>
        Add New Task +
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <% [["Total Tasks", @total_count, "border-gray-200"], ["Pending", @pending_count, "border-yellow-400"], ["In Progress", @in_progress_count, "border-blue-400"], ["Completed", @done_count, "border-green-400"]].each do |label, count, border| %>
      <div class="bg-white p-6 rounded-[2rem] shadow-sm border-b-4 <%= border %>">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest"><%= label %></p>
        <p class="text-3xl font-black text-gray-900 mt-1"><%= count %></p>
      </div>
    <% end %>
  </div>

  <div class="flex flex-col lg:flex-row justify-between items-center gap-6 mb-8">
    <div class="flex flex-wrap items-center gap-4">
      <div class="bg-white p-1 rounded-2xl shadow-sm border border-gray-100 flex">
        <%= link_to "All", tasks_path(status: nil, sort: params[:sort], per_page: @per_page), class: "px-6 py-2 rounded-xl text-xs font-bold transition #{params[:status].blank? ? 'bg-gray-900 text-white shadow-md' : 'text-gray-500 hover:bg-gray-50'}" %>
        <% ['Pending', 'In Progress', 'Done'].each do |s| %>
          <%= link_to s, tasks_path(status: s, sort: params[:sort], per_page: @per_page), class: "px-6 py-2 rounded-xl text-xs font-bold transition #{params[:status] == s ? 'bg-gray-900 text-white shadow-md' : 'text-gray-500 hover:bg-gray-50'}" %>
        <% end %>
      </div>

      <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-2xl border border-gray-100 shadow-sm">
        <span class="text-[10px] font-black text-gray-400 uppercase tracking-tighter">Sort By:</span>
        <%= link_to "Name", tasks_path(sort: 'title', direction: 'asc', status: params[:status], per_page: @per_page), class: "text-xs font-bold #{params[:sort] == 'title' ? 'text-blue-600' : 'text-gray-500 hover:text-blue-500'}" %>
        <div class="w-1 h-1 bg-gray-200 rounded-full"></div>
        <%= link_to "Date", tasks_path(sort: 'due_date', direction: 'asc', status: params[:status], per_page: @per_page), class: "text-xs font-bold #{params[:sort] == 'due_date' ? 'text-blue-600' : 'text-gray-500 hover:text-blue-500'}" %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
    <% @tasks.each do |task| %>
      <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-50 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group">
        <div>
          <div class="flex justify-between items-start mb-6">
            <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest border <%= case task.status when 'Done' then 'bg-green-50 text-green-600 border-green-100' when 'In Progress' then 'bg-blue-50 text-blue-600 border-blue-100' else 'bg-yellow-50 text-yellow-600 border-yellow-100' end %>">
              <%= task.status %>
            </span>
            <% if task.due_date %>
              <div class="text-right">
                <p class="text-[9px] font-black text-gray-300 uppercase tracking-tighter">Due Date</p>
                <% is_overdue = task.due_date < Time.current && task.status != 'Done' %>
                <p class="text-[11px] font-bold <%= is_overdue ? 'text-red-500 animate-pulse' : 'text-gray-500' %>">
                  <%= task.due_date.strftime("%b %d, %Y") %>
                  <% if is_overdue %>
                    <span class="block text-[8px] uppercase tracking-tighter font-black">Overdue!</span>
                  <% end %>
                </p>
              </div>
            <% end %>
          </div>
          <h2 class="text-2xl font-black text-gray-900 mb-3 group-hover:text-blue-600 transition-colors"><%= task.title %></h2>
          <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-8"><%= task.description %></p>
        </div>
        
        <div class="flex justify-between items-center pt-6 border-t border-gray-50">
          <%= link_to "View Details", task, class: "text-xs font-black text-blue-600 tracking-widest hover:underline" %>
          <div class="flex items-center gap-1">
            <%= link_to edit_task_path(task), class: "p-2 rounded-xl text-gray-300 hover:text-blue-600 hover:bg-blue-50 transition-all" do %>
               <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2.5 2.5 0 113.536 3.536L12 14.207H8v-4l9.293-9.293z" /></svg>
            <% end %>
            <%= button_to task, method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "p-2 rounded-xl text-gray-300 hover:text-red-600 hover:bg-red-50 transition-all" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%# Centered Data Table Pagination %>
  <div class="flex flex-col md:flex-row items-center justify-center gap-8 py-6 px-4 border-t border-gray-100 text-sm text-gray-600 font-medium bg-white rounded-b-[2.5rem] shadow-sm">
    <div class="flex items-center gap-3">
      <span class="text-gray-400">Rows per page:</span>
      <div class="relative">
        <%= form_with url: tasks_path, method: :get, class: "flex items-center" do |f| %>
          <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
          <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
          <%= f.select :per_page, [3, 6, 10, 25, 50], { selected: @per_page }, 
              onchange: "this.form.requestSubmit()", 
              class: "appearance-none bg-white border border-gray-200 rounded-lg px-3 py-1.5 pr-8 focus:outline-none focus:ring-2 focus:ring-blue-500/20 cursor-pointer transition-all" %>
          <div class="absolute right-2 pointer-events-none text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </div>
        <% end %>
      </div>
    </div>

    <div class="min-w-[100px] text-center text-gray-500 font-bold border-x border-gray-50 px-6">
      <% start_idx = (@tasks.current_page - 1) * @tasks.limit_value + 1 %>
      <% end_idx = [start_idx + @tasks.length - 1, @total_count].min %>
      <%= @total_count > 0 ? "#{start_idx}-#{end_idx}" : "0" %> <span class="text-gray-300 mx-1">of</span> <%= @total_count %>
    </div>

    <div class="flex items-center gap-1">
      <%= link_to tasks_path(page: 1, per_page: @per_page, status: params[:status], sort: params[:sort]), class: "p-2 rounded-lg transition-colors #{@tasks.first_page? ? 'text-gray-200 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100 hover:text-blue-600'}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" /></svg>
      <% end %>

      <%= link_to tasks_path(page: @tasks.prev_page, per_page: @per_page, status: params[:status], sort: params[:sort]), class: "p-2 rounded-lg transition-colors #{!@tasks.prev_page ? 'text-gray-200 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100 hover:text-blue-600'}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      <% end %>

      <%= link_to tasks_path(page: @tasks.next_page, per_page: @per_page, status: params[:status], sort: params[:sort]), class: "p-2 rounded-lg transition-colors #{!@tasks.next_page ? 'text-gray-200 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100 hover:text-blue-600'}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <% end %>

      <%= link_to tasks_path(page: @tasks.total_pages, per_page: @per_page, status: params[:status], sort: params[:sort]), class: "p-2 rounded-lg transition-colors #{@tasks.last_page? ? 'text-gray-200 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100 hover:text-blue-600'}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" /></svg>
      <% end %>
    </div>
  </div>
</div>