<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Header Section %>
  <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
    <div>
      <h1 class="text-4xl font-black text-gray-900 text-center md:text-left">My Tasks</h1>
      <p class="text-gray-500 mt-2">Manage your daily activities and deadlines</p>
    </div>
    <%= link_to "Add New Task +", new_task_path, class: "bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:shadow-lg hover:bg-blue-700 transition w-full md:w-auto text-center" %>
  </div>

  <%# Statistics Dashboard %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total Tasks</p>
      <p class="text-3xl font-black text-gray-900 mt-1"><%= @total_count %></p>
    </div>
    
    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-yellow-400">
      <p class="text-[10px] font-bold text-yellow-600 uppercase tracking-widest">Pending</p>
      <p class="text-3xl font-black text-gray-900 mt-1"><%= @pending_count %></p>
    </div>

    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-blue-400">
      <p class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">In Progress</p>
      <p class="text-3xl font-black text-gray-900 mt-1"><%= @in_progress_count %></p>
    </div>

    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-green-400">
      <p class="text-[10px] font-bold text-green-600 uppercase tracking-widest">Completed</p>
      <p class="text-3xl font-black text-gray-900 mt-1"><%= @done_count %></p>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-8">
    <%# Filter Tabs %>
    <div class="flex flex-wrap items-center gap-2 bg-gray-100 p-1.5 rounded-xl w-fit">
      <%= link_to "All Tasks", tasks_path(query: params[:query]), 
          class: "px-5 py-2 rounded-lg font-semibold text-sm transition #{params[:status].blank? ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
      
      <% ['Pending', 'In Progress', 'Done'].each do |status| %>
        <%= link_to status, tasks_path(status: status, query: params[:query]), 
            class: "px-5 py-2 rounded-lg font-semibold text-sm transition #{params[:status] == status ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
      <% end %>
    </div>

    <%# Search Form %>
    <%= form_with url: tasks_path, method: :get, class: "flex w-full lg:w-72" do |f| %>
      <%= f.hidden_field :status, value: params[:status] if params[:status].present? %>
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <%= f.text_field :query, value: params[:query], placeholder: "Search by title...", 
            class: "block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-xl bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent sm:text-sm shadow-sm" %>
      </div>
    <% end %>
  </div>

  <% if @tasks.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @tasks.each do |task| %>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition flex flex-col justify-between h-full group/card">
          <div>
            <div class="flex justify-between items-start mb-4">
              <%# Quick Status Toggle Button %>
              <%= button_to toggle_status_task_path(task, current_filter: params[:status]), method: :patch, class: "transition transform active:scale-95" do %>
                <span class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider border transition-colors <%= case task.status 
                  when 'Done' then 'bg-green-50 text-green-600 border-green-200 hover:bg-green-100'
                  when 'In Progress' then 'bg-blue-50 text-blue-600 border-blue-200 hover:bg-blue-100'
                  else 'bg-yellow-50 text-yellow-600 border-yellow-200 hover:bg-yellow-100'
                end %>">
                  ● <%= task.status %>
                </span>
              <% end %>
              
              <% if task.due_date %>
                <div class="text-right">
                  <p class="text-[9px] font-bold text-gray-400 uppercase">Due Date</p>
                  <p class="text-xs font-semibold <%= task.due_date < Time.now && task.status != 'Done' ? 'text-red-500' : 'text-gray-600' %>">
                    <%= task.due_date.strftime("%b %d, %H:%M") %>
                  </p>
                </div>
              <% end %>
            </div>

            <h2 class="text-xl font-bold text-gray-800 mb-2 truncate group-hover/card:text-blue-600 transition-colors"><%= task.title %></h2>
            <p class="text-gray-500 text-sm line-clamp-3 mb-6"><%= task.description %></p>
          </div>
          
          <div class="flex justify-between items-center mt-auto pt-4 border-t border-gray-50">
            <%= link_to "Details →", task, class: "text-blue-600 font-bold text-sm hover:text-blue-800 transition" %>
            <div class="flex gap-3">
               <%= link_to edit_task_path(task), class: "text-gray-300 hover:text-blue-500 transition" do %>
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2.5 2.5 0 113.536 3.536L12 14.207H8v-4l9.293-9.293z" />
                 </svg>
               <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# Empty State %>
    <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-gray-200 shadow-sm">
      <div class="mb-4 flex justify-center text-gray-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <p class="text-gray-400 text-lg font-medium">No tasks match your criteria.</p>
      <%= link_to "Clear all filters", tasks_path, class: "text-blue-600 font-bold mt-3 inline-block hover:underline" %>
    </div>
  <% end %>
</div>