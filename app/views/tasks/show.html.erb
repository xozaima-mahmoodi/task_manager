<div class="max-w-2xl mx-auto mt-10" dir="ltr">
  <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
    <div class="p-8">
      <div class="flex justify-between items-start mb-6">
        <h1 class="text-3xl font-bold text-gray-900"><%= @task.title %></h1>
        <span class="px-4 py-1 rounded-full text-sm font-bold <%= case @task.status 
          when 'Done' then 'bg-green-100 text-green-700'
          when 'In Progress' then 'bg-blue-100 text-blue-700'
          else 'bg-yellow-100 text-yellow-700'
        end %>">
          <%= @task.status %>
        </span>
      </div>

      <div class="mb-8">
        <h3 class="text-sm font-semibold text-gray-400 uppercase mb-2">Description</h3>
        <p class="text-gray-700 leading-relaxed text-lg"><%= @task.description %></p>
      </div>

      <div class="flex border-t border-gray-100 pt-6 gap-4">
        <%= link_to "Edit Task", edit_task_path(@task), class: "flex-1 text-center bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition" %>
        <%= button_to "Delete", @task, method: :delete, form: { data: { confirm: "Are you sure?" } }, class: "flex-1 text-center bg-red-50 text-red-600 py-3 rounded-xl font-bold hover:bg-red-100 transition" %>
      </div>
      
      <div class="mt-4 text-center">
        <%= link_to "← Back to all tasks", tasks_path, class: "text-gray-400 hover:text-gray-600 text-sm" %>
      </div>
    </div>
  </div>
</div>