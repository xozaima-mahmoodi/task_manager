<div class="max-w-3xl mx-auto px-4 py-12">
  <%# Navigation Header %>
  <div class="flex items-center justify-between mb-8">
    <%= link_to tasks_path, class: "flex items-center gap-2 text-gray-400 hover:text-gray-900 transition-colors group" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <span class="text-xs font-black uppercase tracking-widest">Back to Dashboard</span>
    <% end %>

    <div class="flex gap-3">
      <%= link_to edit_task_path(@task), class: "p-3 rounded-2xl bg-gray-50 text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-all shadow-sm border border-gray-100" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2.5 2.5 0 113.536 3.536L12 14.207H8v-4l9.293-9.293z" />
        </svg>
      <% end %>

      <%= button_to @task, method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this task?" } }, class: "p-3 rounded-2xl bg-gray-50 text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all shadow-sm border border-gray-100" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      <% end %>
    </div>
  </div>

  <%# Main Content Card %>
  <div class="bg-white rounded-[3rem] shadow-xl shadow-blue-500/5 border border-gray-50 overflow-hidden">
    <div class="p-8 md:p-12">
      <%# Status and Date Badges %>
      <div class="flex flex-wrap items-center gap-4 mb-8">
        <span class="px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest border <%= case @task.status 
            when 'Done' then 'bg-green-50 text-green-600 border-green-100'
            when 'In Progress' then 'bg-blue-50 text-blue-600 border-blue-100'
            else 'bg-yellow-50 text-yellow-600 border-yellow-100'
          end %>">
          <%= @task.status %>
        </span>

        <% if @task.due_date %>
          <% is_overdue = @task.due_date < Time.current && @task.status != 'Done' %>
          <div class="flex items-center gap-2 px-4 py-1.5 rounded-xl bg-gray-50 border border-gray-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 <%= is_overdue ? 'text-red-500' : 'text-gray-400' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-[10px] font-black uppercase tracking-widest <%= is_overdue ? 'text-red-500' : 'text-gray-500' %>">
              <%= @task.due_date.strftime("%B %d, %Y") %>
              <%= "(Overdue)" if is_overdue %>
            </span>
          </div>
        <% end %>
      </div>

      <%# Title %>
      <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-8 leading-tight">
        <%= @task.title %>
      </h1>

      <%# Description Area %>
      <div class="prose prose-blue max-w-none">
        <p class="text-xs font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Description</p>
        <div class="bg-gray-50/50 rounded-[2rem] p-6 md:p-8 border border-gray-100">
          <p class="text-gray-600 text-lg leading-relaxed italic">
            <%= @task.description.present? ? @task.description : "No description provided for this task." %>
          </p>
        </div>
      </div>
    </div>

    <%# Footer / Metadata %>
    <div class="bg-gray-50 px-8 md:px-12 py-6 border-t border-gray-100 flex justify-between items-center text-[10px] font-black uppercase tracking-widest text-gray-400">
      <span>Created <%= time_ago_in_words(@task.created_at) %> ago</span>
      <span>Last updated <%= time_ago_in_words(@task.updated_at) %> ago</span>
    </div>
  </div>
</div>