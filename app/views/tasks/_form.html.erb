<%= form_with(model: task, class: "space-y-6 bg-white p-8 rounded-xl shadow-sm border border-gray-100") do |form| %>
  <% if task.errors.any? %>
    <div class="bg-red-50 text-red-500 p-4 rounded-lg">
      <h2><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h2>
      <ul class="list-disc ml-5">
        <% task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_field :title, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 p-3 border" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 4, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 p-3 border" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= form.label :status, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.select :status, ['Pending', 'In Progress', 'Done'], {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 p-3 border bg-white" %>
    </div>

    <div>
      <%= form.label :due_date, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.datetime_local_field :due_date, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 p-3 border bg-white" %>
    </div>
  </div>

  <div class="flex gap-3 pt-4">
    <%= form.submit class: "bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 cursor-pointer transition" %>
    <%= link_to "Back", tasks_path, class: "bg-gray-100 text-gray-600 px-6 py-3 rounded-lg font-bold hover:bg-gray-200 transition text-center" %>
  </div>
<% end %>