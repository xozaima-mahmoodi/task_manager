<%= form_with(model: task, class: "space-y-6") do |f| %>
  
  <% if task.errors.any? %>
    <div class="bg-red-50 border border-red-100 text-red-600 p-4 rounded-2xl mb-6">
      <h2 class="font-bold text-sm mb-2"><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h2>
      <ul class="list-disc list-inside text-xs space-y-1">
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1" %>
    <%= f.text_field :title, placeholder: "What needs to be done?", class: "w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50 text-gray-900 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white outline-none transition-all placeholder:text-gray-300" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1" %>
    <%= f.text_area :description, rows: 4, placeholder: "Add some details...", class: "w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50 text-gray-900 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white outline-none transition-all placeholder:text-gray-300" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :status, class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1" %>
      <%= f.select :status, ['Pending', 'In Progress', 'Done'], {}, class: "w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50 text-gray-900 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white outline-none transition-all appearance-none" %>
    </div>

    <div>
      <%= f.label :due_date, class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 ml-1" %>
      <%= f.datetime_field :due_date, class: "w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50 text-gray-900 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white outline-none transition-all" %>
    </div>
  </div>

  <div class="pt-4">
    <%= f.submit task.new_record? ? "Create Task" : "Update Task", class: "w-full bg-blue-600 text-white py-4 rounded-2xl font-black shadow-lg shadow-blue-500/30 hover:bg-blue-700 hover:-translate-y-0.5 active:translate-y-0 transition-all cursor-pointer" %>
  </div>

<% end %>