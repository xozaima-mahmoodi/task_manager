<!DOCTYPE html>
<html>
  <head>
    <title>TaskManager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <nav class="bg-white border-b border-gray-200 py-4 shadow-sm mb-8">
      <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
        <div class="text-2xl font-bold text-blue-600">TaskApp 🚀</div>
        <div class="flex items-center gap-6">
          <% if user_signed_in? %>
            <span class="text-sm text-gray-600"><%= current_user.email %></span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm font-bold" %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "text-gray-600 font-medium" %>
            <%= link_to "Sign up", new_user_registration_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg font-bold ml-4" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4">
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <% if notice %>
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-4">
            <%= notice %>
          </div>
        <% end %>

        <% if alert %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
            <%= alert %>
          </div>
        <% end %>
      </div>
      <%= yield %>
    </main>
  </body>
</html>