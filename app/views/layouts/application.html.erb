<!DOCTYPE html>
<html>
  <head>
    <title>TaskMaster</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 antialiased">
    <div class="fixed top-4 right-4 z-50 flex flex-col gap-2">
      <% if notice %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-6 py-3 rounded-xl shadow-lg font-bold text-sm">
          <%= notice %>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-6 py-3 rounded-xl shadow-lg font-bold text-sm">
          <%= alert %>
        </div>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <nav class="bg-white border-b border-gray-200 h-16 flex items-center shadow-sm">
        <div class="max-w-7xl mx-auto px-4 w-full flex justify-between items-center">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center shadow-lg shadow-blue-500/20">
              <span class="text-white font-black text-sm">T</span>
            </div>
            <span class="font-bold text-gray-900 tracking-tight">TaskApp 🚀</span>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="hidden sm:flex flex-col items-end">
              <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest">User Profile</span>
              <span class="text-sm font-bold text-gray-900">
                <%= current_user.name.present? ? current_user.name : current_user.email %>
              </span>
            </div>
            
            <%= link_to "Sign out", destroy_user_session_path, 
                class: "bg-red-50 text-red-600 px-4 py-2 rounded-xl text-xs font-bold hover:bg-red-100 transition-all border border-red-100" %>
          </div>
        </div>
      </nav>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>